{
  "name": "markdown-ai-translate-by-junes",
  "displayName": "Markdown AI Translate By junes",
  "description": "%extension.description%",
  "version": "1.0.2",
  "publisher": "junes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/junxin367/Markdown-AI-Translate.git"
  },
  "icon": "resources/icon.png",
  "keywords": [
    "translate",
    "markdown",
    "translation",
    "bilingual",
    "chinese",
    "openai",
    "deepseek",
    "llm"
  ],
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdownAiTranslate.translate",
    "onCommand:markdownAiTranslate.openSettings",
    "onCommand:markdownAiTranslate.clearCache",
    "onCommand:markdownAiTranslate.openPreview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownAiTranslate.translate",
        "title": "%commands.translate.title%",
        "shortTitle": "%commands.translate.shortTitle%",
        "category": "%commands.category%",
        "icon": "resources/icon.svg"
      },
      {
        "command": "markdownAiTranslate.openSettings",
        "title": "%commands.openSettings.title%",
        "category": "%commands.category%"
      },
      {
        "command": "markdownAiTranslate.clearCache",
        "title": "%commands.clearCache.title%",
        "category": "%commands.category%"
      },
      {
        "command": "markdownAiTranslate.openPreview",
        "title": "%commands.openPreview.title%",
        "category": "%commands.category%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownAiTranslate.translate",
          "when": "resourceLangId == markdown || resourceLangId == skill || resourceExtname == .md",
          "group": "navigation@-10"
        },
        {
          "command": "markdownAiTranslate.openPreview",
          "when": "resourceLangId == markdown && markdownAiTranslate.isTranslationPreviewDocument",
          "group": "navigation@-9"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "markdownDescription": "%configuration.description%",
      "properties": {
        "markdownAiTranslate.apiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "order": 1,
          "markdownDescription": "%settings.apiEndpoint.description%"
        },
        "markdownAiTranslate.apiKey": {
          "type": "string",
          "default": "",
          "order": 2,
          "markdownDescription": "%settings.apiKey.description%"
        },
        "markdownAiTranslate.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "order": 3,
          "markdownDescription": "%settings.model.description%"
        },
        "markdownAiTranslate.targetLanguage": {
          "type": "string",
          "default": "%settings.targetLanguage.default%",
          "order": 4,
          "markdownDescription": "%settings.targetLanguage.description%"
        },
        "markdownAiTranslate.customPrompt": {
          "type": "string",
          "default": "%settings.customPrompt.default%",
          "order": 5,
          "editPresentation": "multilineText",
          "markdownDescription": "%settings.customPrompt.description%"
        },
        "markdownAiTranslate.codeCommentPrompt": {
          "type": "string",
          "default": "%settings.codeCommentPrompt.default%",
          "order": 6,
          "editPresentation": "multilineText",
          "markdownDescription": "%settings.codeCommentPrompt.description%"
        },
        "markdownAiTranslate.translateCodeComments": {
          "type": "boolean",
          "default": false,
          "order": 7,
          "markdownDescription": "%settings.translateCodeComments.description%"
        },
        "markdownAiTranslate.openMode": {
          "type": "string",
          "default": "sideBySide",
          "enum": [
            "sideBySide",
            "tab"
          ],
          "enumItemLabels": [
            "%settings.openMode.sideBySide.label%",
            "%settings.openMode.tab.label%"
          ],
          "enumDescriptions": [
            "%settings.openMode.sideBySide.description%",
            "%settings.openMode.tab.description%"
          ],
          "order": 8,
          "markdownDescription": "%settings.openMode.description%"
        },
        "markdownAiTranslate.openTarget": {
          "type": "string",
          "default": "file",
          "enum": [
            "file",
            "preview"
          ],
          "enumItemLabels": [
            "%settings.openTarget.file.label%",
            "%settings.openTarget.preview.label%"
          ],
          "enumDescriptions": [
            "%settings.openTarget.file.description%",
            "%settings.openTarget.preview.description%"
          ],
          "order": 9,
          "markdownDescription": "%settings.openTarget.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch --sourcemap",
    "lint": "tsc --noEmit",
    "package": "node scripts/package-vsix.cjs"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "markdown-it": "^14.0.0"
  }
}
